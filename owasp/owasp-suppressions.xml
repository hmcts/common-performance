<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- azure -->
    <suppress>
        <packageUrl regex="true">^pkg:maven/com\.azure/.*$</packageUrl>
        <cve>CVE-2023-36415</cve>
        <cve>CVE-2024-35255</cve>
        <cve>CVE-2026-33117</cve>
    </suppress>

    <!-- msal4j -->
    <suppress>
        <packageUrl>pkg:maven/com.microsoft.azure/msal4j@1.23.1</packageUrl>
        <cve>CVE-2024-35255</cve>
    </suppress>

    <!-- gatling -->
    <suppress>
        <packageUrl regex="true">^pkg:maven/io\.gatling/gatling-shared-(cli|model_2\.13|util_2\.13)@.*$</packageUrl>
        <cve>CVE-2025-51306</cve>
        <cve>CVE-2025-51308</cve>
    </suppress>

    <!-- jackson-databind -->
    <suppress>
        <packageUrl regex="true">^pkg:maven/com\.fasterxml\.jackson\.core/jackson-databind@.*$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>

    <!-- jmespath -->
    <suppress>
        <packageUrl regex="true">^pkg:maven/io\.burt/jmespath.*$</packageUrl>
        <cve>CVE-2022-32511</cve>
        <cve>CVE-2026-54133</cve>
    </suppress>

    <!-- netty -->
    <suppress>
        <packageUrl regex="true">^pkg:maven/io\.netty/netty.*$</packageUrl>
        <cve>CVE-2026-44891</cve>
        <cve>CVE-2026-55831</cve>
        <cve>CVE-2026-55833</cve>
    </suppress>

</suppressions>
